@page "/counter/{IncrementAmount:int?}"
@rendermode InteractiveServer
@using BlazorApp1.Components

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<MyButton OnClick="IncrementCount">Click me!</MyButton>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="() => currentCount++ ">Click me</button>
<button class="btn btn-primary" @onclick="ResetCount">Reset</button>

@if (currentCount % 10 == 0 && currentCount != 0)
{
    <p>Congratulations! You've reached a multiple of 10!</p>
}

<ul>
    @for (int i = 0; i < currentCount; i++)
    {
        <li>Clicked!</li>
    }
</ul>

<div class="mt-3">
    <input @bind="text" @bind:event="oninput" @bind:after="Search" placeholder="Type something..." />
    <button @onclick="() => text = string.Empty">Clear</button>
    <p>@text</p>
    <p>@searchResult</p>
</div>

@code {
    private int currentCount = 0;
    private string text = "";

    private string searchResult = "";

    [Parameter] 
    public int IncrementAmount { get; set; } = 1;

    private void IncrementCount(MouseEventArgs e)
    {
    currentCount += IncrementAmount;
    }

    async Task IncrementCountAsync()
    {
        currentCount += IncrementAmount;
    }
    
    private void ResetCount()
    {
        currentCount = 0;
    }

    async Task Search(){
        searchResult = "Searching....";
        await Task.Delay(2000); // Simulate a delay for the search operation
        searchResult = $"Found {Random.Shared.Next(1, 100)} results for '{text}'";
    }
}
